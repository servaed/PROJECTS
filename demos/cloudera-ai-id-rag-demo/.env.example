# ─────────────────────────────────────────────────────────────
# cloudera-ai-id-rag-demo — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── LLM Provider ──────────────────────────────────────────────
# Choose one:
#   cloudera   Cloudera AI Inference (OpenAI-compatible endpoint)
#   openai     OpenAI API directly
#   azure      Azure OpenAI
#   bedrock    Amazon Bedrock (Converse API, any supported model)
#   anthropic  Anthropic API directly (Claude models)
#   local      Local server: Ollama, LM Studio, vLLM, etc.
LLM_PROVIDER=cloudera

# ── Cloudera AI Inference ──────────────────────────────────────
# OpenAI-compatible endpoint exposed by Cloudera AI Inference Service.
# Find this URL in AI Inference → your model endpoint → "API URL".
CLOUDERA_INFERENCE_URL=https://your-workspace.cloudera.site/namespaces/serving/endpoints/your-model
CLOUDERA_INFERENCE_API_KEY=your-api-key-here
CLOUDERA_INFERENCE_MODEL_ID=meta-llama-3-8b-instruct

# ── OpenAI ─────────────────────────────────────────────────────
# Used when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL_ID=gpt-4o

# ── Azure OpenAI ───────────────────────────────────────────────
# Used when LLM_PROVIDER=azure
# AZURE_OPENAI_DEPLOYMENT is the deployment name you created in Azure, e.g. "my-gpt4o"
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-azure-api-key
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ── Amazon Bedrock ─────────────────────────────────────────────
# Used when LLM_PROVIDER=bedrock
# Supported models (examples):
#   anthropic.claude-3-5-sonnet-20241022-v2:0
#   anthropic.claude-3-sonnet-20240229-v1:0
#   meta.llama3-70b-instruct-v1:0
#   mistral.mistral-large-2402-v1:0
#   amazon.titan-text-premier-v1:0
#
# Credentials (pick one approach):
#   A) Leave ACCESS_KEY/SECRET_KEY empty to use the SDK default chain
#      (env vars AWS_*, IAM instance role, ECS task role — recommended for production)
#   B) Set BEDROCK_PROFILE to use a named profile from ~/.aws/credentials
#   C) Set ACCESS_KEY + SECRET_KEY explicitly (not recommended in production)
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_ACCESS_KEY=
BEDROCK_SECRET_KEY=
BEDROCK_SESSION_TOKEN=
BEDROCK_PROFILE=

# ── Anthropic (direct) ─────────────────────────────────────────
# Used when LLM_PROVIDER=anthropic
# Supported models: claude-3-5-sonnet-20241022, claude-3-opus-20240229, etc.
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ANTHROPIC_MODEL_ID=claude-3-5-sonnet-20241022

# ── Local / Ollama / vLLM / LM Studio ─────────────────────────
# Used when LLM_PROVIDER=local
# Point LOCAL_LLM_URL at any OpenAI-compatible local server.
# Examples:
#   Ollama    : http://localhost:11434/v1
#   LM Studio : http://localhost:1234/v1
#   vLLM      : http://localhost:8000/v1
LOCAL_LLM_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL_ID=llama3
LOCAL_LLM_API_KEY=no-key

# ── Embeddings ─────────────────────────────────────────────────
# "local" uses sentence-transformers (no API key, supports Bahasa Indonesia)
# "openai" calls OpenAI embeddings API
EMBEDDINGS_PROVIDER=local
EMBEDDINGS_MODEL=intfloat/multilingual-e5-base

# ── Vector Store ───────────────────────────────────────────────
VECTOR_STORE_TYPE=faiss
VECTOR_STORE_PATH=./data/vector_store

# ── Document Storage ───────────────────────────────────────────
DOCS_SOURCE_PATH=./data/sample_docs
DOCS_STORAGE_TYPE=local

# HDFS (only when DOCS_STORAGE_TYPE=hdfs)
HDFS_URL=http://namenode:9870
HDFS_USER=hdfs

# Object storage (only when DOCS_STORAGE_TYPE=s3)
S3_ENDPOINT_URL=https://s3-compatible.example.com
S3_BUCKET=enterprise-docs
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ── Database / SQL ─────────────────────────────────────────────
# SQLAlchemy URL — use read-only credentials in production
# sqlite    : sqlite:///./data/sample_tables/demo.db
# PostgreSQL: postgresql+psycopg2://user:pass@host:5432/dbname
# Hive/CDP  : hive+pyhive://user@host:10000/default
DATABASE_URL=sqlite:///./data/sample_tables/demo.db
SQL_APPROVED_TABLES=kredit_umkm,nasabah,cabang
SQL_MAX_ROWS=500

# ── Application ────────────────────────────────────────────────
APP_PORT=8080
APP_TITLE=Asisten Enterprise Cloudera AI
LOG_LEVEL=INFO
HISTORY_PATH=./.claude/history
