# ─────────────────────────────────────────────
# cloudera-ai-id-rag-demo — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────

# ── LLM Provider ──────────────────────────────
# Set to "cloudera", "openai", or "local"
LLM_PROVIDER=cloudera

# Cloudera AI Inference endpoint (OpenAI-compatible)
# Example: https://your-cml-workspace.cloudera.site/namespaces/serving/endpoints/your-model
CLOUDERA_INFERENCE_URL=https://your-cml-workspace.example.com/namespaces/serving/endpoints/your-model
CLOUDERA_INFERENCE_API_KEY=your-api-key-here
CLOUDERA_INFERENCE_MODEL_ID=meta-llama-3-8b-instruct

# OpenAI-compatible fallback (used when LLM_PROVIDER=openai or local)
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL_ID=gpt-4o

# ── Embeddings ─────────────────────────────────
# "local" uses sentence-transformers; "openai" calls OpenAI embeddings API
EMBEDDINGS_PROVIDER=local
EMBEDDINGS_MODEL=intfloat/multilingual-e5-base

# ── Vector Store ───────────────────────────────
# "faiss" for local/demo mode; extend to "chroma" or "enterprise" as needed
VECTOR_STORE_TYPE=faiss
VECTOR_STORE_PATH=./data/vector_store

# ── Document Storage ───────────────────────────
# Path to source documents (local path or HDFS-style URI)
DOCS_SOURCE_PATH=./data/sample_docs
# Options: "local", "hdfs", "s3"
DOCS_STORAGE_TYPE=local

# HDFS (only used when DOCS_STORAGE_TYPE=hdfs)
HDFS_URL=http://namenode:9870
HDFS_USER=hdfs

# Object storage (only used when DOCS_STORAGE_TYPE=s3)
S3_ENDPOINT_URL=https://s3-compatible.example.com
S3_BUCKET=enterprise-docs
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ── Database / SQL ─────────────────────────────
# SQLAlchemy connection URL — use read-only credentials
# Examples:
#   sqlite:///./data/sample.db
#   postgresql+psycopg2://user:pass@host:5432/dbname
#   hive+pyhive://user@host:10000/default
DATABASE_URL=sqlite:///./data/sample_tables/demo.db

# Approved tables (comma-separated; leave empty to allow all discovered tables)
SQL_APPROVED_TABLES=kredit_umkm,nasabah,cabang

# Max rows returned per query
SQL_MAX_ROWS=500

# ── Application ────────────────────────────────
APP_PORT=8080
APP_TITLE=Asisten Enterprise Cloudera AI
LOG_LEVEL=INFO

# Session history storage path
HISTORY_PATH=./.claude/history
