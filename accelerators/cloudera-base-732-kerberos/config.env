#!/usr/bin/env bash
# =============================================================================
# config.env — Cloudera Base 7.3.2 + FreeIPA Kerberos — SINGLE NODE
# Platform: RHEL 9 | Edit ALL values before running install.sh
# =============================================================================

# =============================================================================
# MASTER PASSWORD — single strong password used for all services
# Requirements: min 12 chars, upper+lower+digit+special, no $ ` \ ' "
# Change this one value to rotate all passwords at once.
# =============================================================================
export MASTER_PASS="Cl0ud3ra@Base732#SE"

# =============================================================================
# Single-Node Topology
# =============================================================================
export NODE_HOST="cdp.se-indo.lab"         # short FQDN — mapped via /etc/hosts
export NODE_IP="10.240.0.44"               # GCP internal IP of this VM

# ALL_HOST_IPS drives /etc/hosts population in 00_system_prep.sh
export ALL_HOST_IPS="${NODE_IP}:${NODE_HOST}"

export CM_HOST="${NODE_HOST}"
export IPA_HOST="${NODE_HOST}"
export WORKER_HOSTS=""
export ALL_HOSTS="${NODE_HOST}"

export DNS_SERVER="8.8.8.8"               # FreeIPA DNS forwarder
export NTP_SERVER="metadata.google.internal"  # GCP metadata NTP

# =============================================================================
# Software Versions
# CM 7.13.2 REQUIRED for Runtime 7.3.2 | Java 17 only | Python 3.11 only
# =============================================================================
export CM_VERSION="7.13.2"
export PARCEL_VERSION="7.3.2"
export PARCEL_BUILD="7.3.2-1.cdh7.3.2.p0.77083870"   # verified from repo manifest.json

# Cloudera paywall credentials (archive.cloudera.com) — SET THESE
export CLOUDERA_REPO_USER="71d807bd-8297-48ca-9f0a-d463e8e6851d"
export CLOUDERA_REPO_PASS="bad773ad937d"

export CM_REPO_BASE="https://${CLOUDERA_REPO_USER}:${CLOUDERA_REPO_PASS}@archive.cloudera.com/p/cm7/${CM_VERSION}/redhat9/yum"
# Correct repo path: cdh7 (not cdp-pvc-ds) — verified 200 OK with credentials
export PARCEL_REPO="https://${CLOUDERA_REPO_USER}:${CLOUDERA_REPO_PASS}@archive.cloudera.com/p/cdh7/${PARCEL_VERSION}/parcels/"

# =============================================================================
# Kerberos / FreeIPA
# REALM must be uppercase of DOMAIN
# =============================================================================
export REALM="SE-INDO.LAB"
export DOMAIN="se-indo.lab"

export IPA_ADMIN_PASS="${MASTER_PASS}"     # FreeIPA admin user password
export IPA_DM_PASS="${MASTER_PASS}"        # FreeIPA Directory Manager password
export KRB5_ADMIN_USER="admin"
export KRB5_ADMIN_PASS="${MASTER_PASS}"

# =============================================================================
# PostgreSQL — all databases use MASTER_PASS
# PostgreSQL 13 support was REMOVED in Cloudera Base 7.3.2
# =============================================================================
export DB_HOST="localhost"
export DB_PORT="5432"
export PG_ADMIN_USER="postgres"
export PG_ADMIN_PASS="${MASTER_PASS}"

export DB_SCM="scm";         export USER_SCM="scm";             export PASS_SCM="${MASTER_PASS}"
export DB_AMON="amon";       export USER_AMON="amon";           export PASS_AMON="${MASTER_PASS}"
export DB_RMAN="rman";       export USER_RMAN="rman";           export PASS_RMAN="${MASTER_PASS}"
export DB_HUE="hue";         export USER_HUE="hue";             export PASS_HUE="${MASTER_PASS}"
export DB_HIVE="metastore";  export USER_HIVE="hive";           export PASS_HIVE="${MASTER_PASS}"
export DB_RANGER="ranger";   export USER_RANGER="rangeradmin";  export PASS_RANGER="${MASTER_PASS}"

# =============================================================================
# Cloudera Manager Admin
# =============================================================================
export CM_ADMIN_USER="admin"
export CM_ADMIN_PASS="${MASTER_PASS}"
export CM_PORT="7180"
export CM_API_VERSION="v51"
export CM_API="http://${CM_HOST}:${CM_PORT}/api/${CM_API_VERSION}"

# =============================================================================
# Cluster Definition
# =============================================================================
export CLUSTER_NAME="CDP-Base-732"
export CLUSTER_FULL_VERSION="${PARCEL_BUILD}"

export DFS_DATA_DIRS="/data/dfs/dn"
export YARN_LOCAL_DIRS="/data/yarn/nm"
export YARN_LOG_DIRS="/var/log/hadoop-yarn/nm"
